<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- ============================================================ -->
        <!-- FORM VIEW INHERITANCE: petshop.species                       -->
        <!-- Add image, short_note and description at appropriate places. -->
        <!-- ============================================================ -->
        <record id="petshop_species_form_view_plus_inherit" model="ir.ui.view">
            <field name="name">petshop.species.form.view.plus.inherit</field>
            <field name="model">petshop.species</field>
            <field name="inherit_id" ref="petshop.petshop_species_form_view"/>
            <field name="arch" type="xml">
                <!-- Avatar image beside the title -->
                <xpath expr="//div[@class='oe_title']" position="before">
                    <field name="image" widget="image" class="oe_avatar"
                        options="{'preview_image': 'image', 'size': [90, 90]}"/>
                </xpath>

                <!-- Short note right under the species name -->
                <xpath expr="//div[@class='oe_title']" position="inside">
                    <h3><field name="short_note" placeholder="e.g., Small furry companion"/></h3>
                </xpath>

                <!-- Detailed description in a dedicated notebook page -->
                <xpath expr="//group[@name='basic_info']" position="after">
                    <notebook>
                        <page name="description" string="Description">
                            <field name="description" nolabel="1"
                                placeholder="Enter detailed characteristics and care notes for this species..."/>
                        </page>
                    </notebook>
                </xpath>
            </field>
        </record>

        <!-- ========================================================== -->
        <!-- LIST VIEW INHERITANCE: petshop.species                     -->
        <!-- Add image, short_note and description as columns.          -->
        <!-- ========================================================== -->
        <record id="petshop_species_list_view_plus_inherit" model="ir.ui.view">
            <field name="name">petshop.species.list.view.plus.inherit</field>
            <field name="model">petshop.species</field>
            <field name="inherit_id" ref="petshop.petshop_species_list_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="image" widget="image" options="{'size': [64, 64]}"/>
                    <field name="short_note"/>
                    <field name="description"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
