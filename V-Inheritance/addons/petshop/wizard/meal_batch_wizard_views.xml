<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_petshop_meal_batch_wizard" model="ir.ui.view">
        <field name="name">view_petshop_meal_batch_wizard</field>
        <field name="model">petshop.meal.batch.wizard</field>
        <field name="arch" type="xml">
            <form string="Batch Create Meals">
                <group>
                    <group>
                        <field name="product_id"/>
                        <field name="volume"/>
                        <field name="meal_time"/>
                    </group>
                    <group/>
                </group>
                <field name="pet_ids"/>
                <footer>
                    <button string="Create Meals" name="action_create_meals"
                        type="object" default_focus="1" class="btn-primary"/>
                    <button string="Cancel" class="btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_petshop_meal_batch_wizard" model="ir.actions.act_window">
        <field name="name">Batch Create Meals</field>
        <field name="res_model">petshop.meal.batch.wizard</field>
        <field name="binding_model_id" ref="model_petshop_pet"/>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_petshop_meal_batch_wizard"/>
    </record>
</odoo>
