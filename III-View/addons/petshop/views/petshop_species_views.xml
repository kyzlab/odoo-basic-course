<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="petshop_species_list_view" model="ir.ui.view">
            <field name="name">petshop_species_list_view</field>
            <field name="model">petshop.species</field>
            <field name="arch" type="xml">
                <list string="Species">
                    <field name="name"/>
                    <field name="environment"/>
                    <field name="is_rare"/>
                    <field name="pet_ids"/>
                </list>
            </field>
        </record>

        <record id="action_petshop_species" model="ir.actions.act_window">
            <field name="name">Species</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">petshop.species</field>
            <field name="view_mode">list,form</field>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('petshop_species_list_view')})]"/>
        </record>

        <!-- Change "parent" attribute → "menu_petshop_configuration" -->
        <menuitem id="menu_petshop_species"
            name="Species"
            action="action_petshop_species"
            sequence="20"
            parent="menu_petshop_configuration"
            groups="base.group_user"/>
    </data>
</odoo>