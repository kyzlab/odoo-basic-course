<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="petshop_species_form_view" model="ir.ui.view">
            <field name="name">petshop_species_form_view</field>
            <field name="model">petshop.species</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" string="Species" class="oe_edit_only"/>
                            <h1><field name="name" placeholder="e.g. Cat"/></h1>
                        </div>
                        <group name="basic_info">
                            <group>
                                <field name="is_rare"/>
                                <field name="environment"/>
                            </group>
                            <group>
                                <field name="pet_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="petshop_species_list_view" model="ir.ui.view">
            <field name="name">petshop_species_list_view</field>
            <field name="model">petshop.species</field>
            <field name="arch" type="xml">
                <list string="Species">
                    <field name="name"/>
                    <field name="environment"/>
                    <field name="is_rare"/>
                    <field name="pet_ids"/>
                </list>
            </field>
        </record>

        <record id="petshop_species_kanban_view" model="ir.ui.view">
            <field name="name">petshop_species_kanban_view</field>
            <field name="model">petshop.species</field>
            <field name="arch" type="xml">
                <kanban>
                    <field name="name"/>
                    <field name="environment"/>
                    <field name="is_rare"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click p-3">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="mt-1">
                                    <span class="badge rounded-pill text-bg-info">
                                        <t t-esc="record.environment.value"/>
                                    </span>
                                    <span t-if="record.is_rare.raw_value"
                                        class="badge rounded-pill text-bg-warning ms-1">Rare</span>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="action_petshop_species" model="ir.actions.act_window">
            <field name="name">Species</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">petshop.species</field>
            <field name="view_mode">list,form,kanban</field>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('petshop_species_list_view')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('petshop_species_form_view')}),
                (0, 0, {'view_mode': 'kanban', 'view_id': ref('petshop_species_kanban_view')})]"/>
        </record>

        <!-- Change "parent" attribute → "menu_petshop_configuration" -->
        <menuitem id="menu_petshop_species"
            name="Species"
            action="action_petshop_species"
            sequence="20"
            parent="menu_petshop_configuration"
            groups="base.group_user"/>
    </data>
</odoo>