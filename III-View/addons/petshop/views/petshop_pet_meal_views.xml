<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_petshop_pet_meal_form" model="ir.ui.view">
            <field name="name">petshop.pet.meal.form</field>
            <field name="model">petshop.pet.meal</field>
            <field name="arch" type="xml">
                <form string="Meal">
                    <sheet>
                        <group>
                            <group string="Pet &amp; Schedule">
                                <field name="pet_id" placeholder="Select the pet receiving this meal"/>
                                <field name="meal_time"/>
                            </group>
                            <group string="Food">
                                <field name="product_id" placeholder="Select the food product"/>
                                <field name="volume" placeholder="Amount in grams"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="petshop_pet_meal_list_view" model="ir.ui.view">
            <field name="name">petshop_pet_meal_list_view</field>
            <field name="model">petshop.pet.meal</field>
            <field name="arch" type="xml">
                <list string="Meals">
                    <field name="pet_id"/>
                    <field name="product_id"/>
                    <field name="volume"/>
                    <field name="meal_time"/>
                </list>
            </field>
        </record>

        <record id="action_petshop_pet_meal" model="ir.actions.act_window">
            <field name="name">Meal</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">petshop.pet.meal</field>
            <field name="view_mode">list,form</field>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('petshop_pet_meal_list_view')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('view_petshop_pet_meal_form')})]"/>
        </record>

        <!-- Change "parent" attribute → "menu_petshop_configuration" -->
        <menuitem id="menu_petshop_pet_meal"
            name="Meal"
            action="action_petshop_pet_meal"
            sequence="40"
            parent="menu_petshop_configuration"
            groups="base.group_user"/>
    </data>
</odoo>