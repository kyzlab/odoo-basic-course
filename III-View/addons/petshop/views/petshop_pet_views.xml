<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="petshop_pet_form_view" model="ir.ui.view">
            <field name="name">petshop_pet_form_view</field>
            <field name="model">petshop.pet</field>
            <field name="arch" type="xml">
                <form>
                    <!-- form content here -->
                    <header>
                        <button name="action_report_sickness" type="object"
                            string="Report Sick" class="oe_default"
                            invisible="state == 'sick'"/>
                        <button name="action_recovered" type="object"
                            string="Recovered" class="oe_default"
                            invisible="state != 'sick'"/>
                        <button name="action_update_feed_time" type="object"
                            string="Feed" class="oe_highlight"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <field name="image" widget="image" class="oe_avatar"/>
                        <div class="oe_title">
                            <label for="name" string="Pet" class="oe_edit_only"/>
                            <h1>
                                <field name="name" placeholder="e.g. Fluffy the Cat"/>
                            </h1>
                            <label for="is_alive"/>
                            <field name="is_alive"/>
                        </div>
                        <!-- ... group, notebook below -->
                        <group name="basic_info" string="Basic Information">
                            <group>
                                <!-- left column (fields above) -->
                                <field name="nickname"/>
                                <field name="species_id" options="{'no_create_edit': True, 'no_open': True}"/>
                                <field name="species_name"/>                                
                                <field name="gender"/>
                                <field name="dob"/>
                                <field name="age" invisible="not dob"/>
                                <field name="weight"/>
                                <field name="weight_pound" class="oe_edit_only"/>
                                <field name="weight_category" invisible="not weight"/>
                            </group>
                            <group>
                                <!-- right column (fields above) -->
                                <field name="feed_time"/>
                                <field name="cage_id" options="{'no_create_edit': True, 'no_open': True}"/>
                                <field name="doctor_id"/>
                                <field name="mother_id"/>
                                <field name="mother_name"/>
                                <field name="father_id"/>
                                <!-- Add siblings -->
                                <field name="sibling_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                        <notebook name="misc">
                            <page name="additional_info" string="Additional Info">
                                <!-- tab content -->
                                <group>
                                    <group>
                                        <label for="introduction" colspan="2"/>
                                        <field name="introduction" colspan="2" nolabel="1"/>
                                    </group>
                                    <group>
                                        <label for="description" colspan="2"/>
                                        <field name="description" colspan="2" nolabel="1"/>
                                    </group>
                                </group>
                            </page>
                            <page name="children" string="Children">
                                <!-- tab content -->
                                <group>
                                    <group>
                                        <field name="number_of_children"/>
                                    </group>
                                    <group/>
                                </group>
                                <group>
                                    <group>
                                        <label for="female_children_ids" colspan="2"/>
                                        <field name="female_children_ids" colspan="2"
                                            nolabel="1" widget="many2many_tags"/>
                                    </group>
                                    <group>
                                        <label for="male_children_ids" colspan="2"/>
                                        <field name="male_children_ids" colspan="2"
                                            nolabel="1" widget="many2many_tags"/>
                                    </group>
                                </group>
                            </page>
                            <page name="others" string="Others">
                                <!-- tab content -->
                                <group>
                                    <group>
                                        <field name="toy_ids" widget="many2many_tags"/>
                                    </group>
                                    <group>
                                        <label for="meal_ids" colspan="2"/>
                                        <field name="meal_ids" colspan="2" nolabel="1">
                                            <list string="Meals" editable="bottom">
                                                <field name="product_id"/>
                                                <field name="volume"/>
                                                <field name="meal_time"/>
                                            </list>
                                        </field>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="petshop_pet_list_view" model="ir.ui.view">
            <field name="name">petshop_pet_list_view</field>
            <field name="model">petshop.pet</field>
            <field eval="1" name="priority"/>
            <field name="arch" type="xml">
                <list string="Pets" default_order="create_date desc"
                    decoration-danger="state == 'sick'"
                    decoration-warning="state == 'quarantine'"
                    decoration-success="state == 'available'"
                    decoration-muted="state == 'removed'"
                    decoration-bf="state == 'sold'"
                    decoration-it="state == 'reserved'">
                    <field name="image" widget="image" options='{"size": [64, 64]}'/>
                    <field name="name"/>
                    <field name="species_id"/>
                    <field name="dob"/>
                    <field name="gender"/>
                    <field name="weight"/>
                    <field name="mother_id"/>
                    <field name="is_alive"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="petshop_pet_list_minimal_view" model="ir.ui.view">
            <field name="name">petshop_pet_list_minimal_view</field>
            <field name="model">petshop.pet</field>
            <field eval="5" name="priority"/>
            <field name="arch" type="xml">
                <list string="Pets" default_order="create_date desc">
                    <field name="name"/>
                    <field name="species_id"/>
                </list>
            </field>
        </record>

        <record id="petshop_pet_kanban_view" model="ir.ui.view">
            <field name="name">petshop_pet_kanban_view</field>
            <field name="model">petshop.pet</field>
            <field name="arch" type="xml">
                <!-- <kanban> -->
                <kanban default_group_by="state" group_create="false" group_delete="false" group_edit="false">
                    <field name="name"/>
                    <field name="image"/>    <!-- declare the binary field -->
                    <field name="species_id"/>
                    <field name="gender"/>
                    <field name="state"/>
                    <field name="cage_id"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click d-flex">
                                <!-- Image section (left) -->
                                <!-- <aside>
                                    <field name="image" widget="image" class="o_image_64_cover" alt="Pet Avatar"/>
                                </aside> -->
                                <aside class="o_kanban_aside_full">
                                    <field name="image" widget="image" class="o_kanban_image_fill w-100" options="{'img_class': 'object-fit-cover'}" alt="Pet Avatar"/>
                                </aside>
                                <!-- Details section (right) -->
                                <main class="ms-3">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <!-- Species and gender as plain text -->
                                    <div class="text-muted small">
                                        <t t-esc="record.species_id.value"/> ·
                                        <t t-esc="record.gender.value"/>
                                    </div>
                                    <div class="mt-1">
                                        <!-- State badge -->
                                        <span t-if="record.state.raw_value=='sick'"
                                            class="badge rounded-pill text-bg-danger"><t t-esc="record.state.value"/></span>
                                        <span t-elif="record.state.raw_value=='quarantine'"
                                            class="badge rounded-pill text-bg-warning"><t t-esc="record.state.value"/></span>
                                        <span t-elif="record.state.raw_value=='removed'"
                                            class="badge rounded-pill text-bg-light"><t t-esc="record.state.value"/></span>
                                        <span t-elif="record.state.raw_value=='sold'"
                                            class="badge rounded-pill text-bg-dark"><t t-esc="record.state.value"/></span>
                                        <span t-elif="record.state.raw_value=='reserved'"
                                            class="badge rounded-pill text-bg-info"><t t-esc="record.state.value"/></span>
                                        <span t-else=""
                                            class="badge rounded-pill text-bg-success"><t t-esc="record.state.value"/></span>

                                        <!-- Cage badge — only show when cage assigned -->
                                        <span t-if="record.cage_id.raw_value"
                                            class="badge rounded-pill text-bg-secondary ms-1">
                                            <t t-esc="record.cage_id.value"/>
                                        </span>
                                    </div>
                                </main>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="petshop_pet_graph_bar_view" model="ir.ui.view">
            <field name="name">petshop.pet.graph.bar.view</field>
            <field name="model">petshop.pet</field>
            <field name="arch" type="xml">
                <graph type="bar" stacked="false">
                    <!-- fields go here -->
                    <field name="species_id" type="row"/>
                    <field name="gender" type="col"/>
                    <field name="weight" type="measure"/>
                </graph>
            </field>
        </record>

        <record id="petshop_pet_graph_line_view" model="ir.ui.view">
            <field name="name">petshop.pet.graph.line.view</field>
            <field name="model">petshop.pet</field>
            <field name="arch" type="xml">
                <graph type="line">
                    <field name="dob" type="row"/>
                    <field name="weight" type="measure"/>
                </graph>
            </field>
        </record>

        <record id="petshop_pet_graph_pie_view" model="ir.ui.view">
            <field name="name">petshop.pet.graph.pie.view</field>
            <field name="model">petshop.pet</field>
            <field name="arch" type="xml">
                <graph type="pie">
                    <field name="gender" type="row"/>
                </graph>
            </field>
        </record>

        <record id="petshop_pet_pivot_view" model="ir.ui.view">
            <field name="name">petshop.pet.pivot.view</field>
            <field name="model">petshop.pet</field>
            <field name="arch" type="xml">
                <pivot display_quantity="False" disable_linking="False">
                    <field name="gender" type="col"/>
                    <field name="cage_id" type="col"/>
                    <field name="species_id" type="row"/>
                    <field name="state" type="row"/>                    
                    <field name="weight" type="measure"/>
                    <!-- Support many measures (stored fields) -->
                    <!-- <field name="number_of_children" type="measure"/> -->
                </pivot>
            </field>
        </record>

        <record id="action_petshop_pet" model="ir.actions.act_window">
            <field name="name">Pets</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">petshop.pet</field>
            <!-- Define "view_mode" and "view_ids" -->
            <field name="view_mode">list,form,kanban,graph,pivot</field>
            <!-- <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('petshop_pet_list_minimal_view')})]"/> -->
            <!-- <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('petshop_pet_list_view')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('petshop_pet_form_view')}),
                (0, 0, {'view_mode': 'kanban', 'view_id': ref('petshop_pet_kanban_view')})]"/> -->
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('petshop_pet_list_view')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('petshop_pet_form_view')}),
                (0, 0, {'view_mode': 'kanban', 'view_id': ref('petshop_pet_kanban_view')}),
                (0, 0, {'view_mode': 'graph', 'view_id': ref('petshop_pet_graph_pie_view')}),
                (0, 0, {'view_mode': 'pivot', 'view_id': ref('petshop_pet_pivot_view')})]"/>
        </record>

        <menuitem id="menu_petshop"
            name="Petshop"
            sequence="10"
            groups="base.group_user"/>

        <menuitem id="menu_petshop_pet"
            name="Pets"
            sequence="10"
            parent="menu_petshop"
            groups="base.group_user"/>

        <menuitem id="menu_petshop_pet_pet"
            name="Pets"
            action="action_petshop_pet"
            sequence="10"
            parent="menu_petshop_pet"
            groups="base.group_user"/>
        
        <!-- New sub-menu "Configuration" -->
        <menuitem id="menu_petshop_configuration"
            name="Configuration"
            sequence="100"
            parent="menu_petshop"
            groups="base.group_user"/>
    </data>
</odoo>