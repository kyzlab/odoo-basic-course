<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>        
        <record id="petshop_pet_list_view" model="ir.ui.view">
            <field name="name">petshop_pet_list_view</field>
            <field name="model">petshop.pet</field>
            <field eval="1" name="priority"/>
            <field name="arch" type="xml">
                <list string="Pets" default_order="create_date desc"
                    decoration-danger="state == 'sick'"
                    decoration-warning="state == 'quarantine'"
                    decoration-success="state == 'available'"
                    decoration-muted="state == 'removed'"
                    decoration-bf="state == 'sold'"
                    decoration-it="state == 'reserved'">
                    <field name="image" widget="image" options='{"size": [64, 64]}'/>
                    <field name="name"/>
                    <field name="species_id"/>
                    <field name="dob"/>
                    <field name="gender"/>
                    <field name="weight"/>
                    <field name="mother_id"/>
                    <field name="is_alive"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="petshop_pet_list_minimal_view" model="ir.ui.view">
            <field name="name">petshop_pet_list_minimal_view</field>
            <field name="model">petshop.pet</field>
            <field eval="5" name="priority"/>
            <field name="arch" type="xml">
                <list string="Pets" default_order="create_date desc">
                    <field name="name"/>
                    <field name="species_id"/>
                </list>
            </field>
        </record>

        <record id="action_petshop_pet" model="ir.actions.act_window">
            <field name="name">Pets</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">petshop.pet</field>
            <!-- Define view_ids -->
            <!-- <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('petshop_pet_list_minimal_view')})]"/> -->
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('petshop_pet_list_view')})]"/>
        </record>

        <menuitem id="menu_petshop"
            name="Petshop"
            sequence="10"
            groups="base.group_user"/>

        <menuitem id="menu_petshop_pet"
            name="Pets"
            sequence="10"
            parent="menu_petshop"
            groups="base.group_user"/>

        <menuitem id="menu_petshop_pet_pet"
            name="Pets"
            action="action_petshop_pet"
            sequence="10"
            parent="menu_petshop_pet"
            groups="base.group_user"/>
        
        <!-- New sub-menu "Configuration" -->
        <menuitem id="menu_petshop_configuration"
            name="Configuration"
            sequence="100"
            parent="menu_petshop"
            groups="base.group_user"/>
    </data>
</odoo>