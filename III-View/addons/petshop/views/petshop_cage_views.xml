<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="petshop_cage_list_view" model="ir.ui.view">
            <field name="name">petshop_cage_list_view</field>
            <field name="model">petshop.cage</field>
            <field name="arch" type="xml">
                <list string="Cages">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="size"/>
                    <field name="description"/>
                    <field name="pet_ids"/>
                </list>
            </field>
        </record>

        <record id="action_petshop_cage" model="ir.actions.act_window">
            <field name="name">Cage</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">petshop.cage</field>
            <field name="view_mode">list,form</field>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('petshop_cage_list_view')})]"/>
        </record>

        <!-- Change "parent" attribute → "menu_petshop_configuration" -->
        <menuitem id="menu_petshop_cage"
            name="Cage"
            action="action_petshop_cage"
            sequence="30"
            parent="menu_petshop_configuration"
            groups="base.group_user"/>
    </data>
</odoo>