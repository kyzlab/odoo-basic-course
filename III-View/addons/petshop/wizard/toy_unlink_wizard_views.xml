<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_petshop_pet_unlink_toy" model="ir.ui.view">
        <field name="name">view_petshop_pet_unlink_toy</field>
        <field name="model">petshop.toy.unlink.wizard</field>
        <field name="arch" type="xml">
            <form string="Unlink All Toys">
                <p>Unlink all toys of the selected pet(s)?</p>
                <footer>
                    <button string="Confirm" name="action_toy_unlink"
                        type="object" default_focus="1" class="btn-primary"/>
                    <button string="Cancel" class="btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_petshop_pet_unlink_toy" model="ir.actions.act_window">
        <field name="name">Unlink All Toys</field>
        <field name="res_model">petshop.toy.unlink.wizard</field>
        <field name="binding_model_id" ref="model_petshop_pet"/>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_petshop_pet_unlink_toy"/>
    </record>
</odoo>
