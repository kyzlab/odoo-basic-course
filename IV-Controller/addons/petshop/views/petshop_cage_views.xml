<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_petshop_cage_form" model="ir.ui.view">
            <field name="name">petshop.cage.form</field>
            <field name="model">petshop.cage</field>
            <field name="arch" type="xml">
                <form string="Cage">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="%(action_petshop_pet)d" type="action" class="oe_stat_button" icon="fa-paw"
                                domain="[('cage_id', '=', id)]">
                                <field string="Pets" name="pet_ids" widget="statinfo"/>
                            </button>
                        </div>
                        <group>
                            <group string="Identification">
                                <field name="name" placeholder="e.g., Large Dog Kennel"/>
                                <field name="code" placeholder="e.g., DOG-01"/>
                                <field name="capacity"/>
                            </group>
                            <group string="Dimensions">
                                <field name="length"/>
                                <field name="width"/>
                                <field name="height"/>
                                <field name="size"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Description">
                                <field name="description" placeholder="Notes about the cage, materials, location..."/>
                            </page>
                            <page string="Pets">
                                <field name="pet_ids" nolabel="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="species_id"/>
                                        <field name="gender"/>
                                        <field name="is_alive"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="petshop_cage_list_view" model="ir.ui.view">
            <field name="name">petshop_cage_list_view</field>
            <field name="model">petshop.cage</field>
            <field name="arch" type="xml">
                <list string="Cages">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="size"/>
                    <field name="description"/>
                    <field name="pet_ids"/>
                </list>
            </field>
        </record>

        <record id="petshop_cage_kanban_view" model="ir.ui.view">
            <field name="name">petshop_cage_kanban_view</field>
            <field name="model">petshop.cage</field>
            <field name="arch" type="xml">
                <kanban>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="size"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click p-3">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="text-muted small">
                                    <t t-esc="record.code.value"/>
                                </div>
                                <div class="mt-2">
                                    <span class="badge rounded-pill text-bg-secondary">
                                        <t t-esc="record.size.value"/>
                                    </span>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="petshop_cage_search_view" model="ir.ui.view">
            <field name="name">petshop.cage.search.view</field>
            <field name="model">petshop.cage</field>
            <field name="arch" type="xml">
                <search string="Search Cages">
                    <!-- elements go here -->
                    <field name="name" string="Cage Name"/>
                    <field name="code" string="Cage Code"/>
                    <field name="pet_ids" string="Pet" filter_domain="[('pet_ids.name', 'ilike', self)]"/>
                    <!-- filters -->
                    <filter string="Occupied" name="occupied_filter" domain="[('pet_ids', '!=', False)]"/>
                    <filter string="Available" name="available_filter" domain="[('pet_ids', '=', False)]"/>
                    <group>
                        <filter string="Code" name="group_by_code" context="{'group_by': 'code'}"/>
                        <filter string="Creation Date" name="group_by_create_date" context="{'group_by': 'create_date:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_petshop_cage" model="ir.actions.act_window">
            <field name="name">Cage</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">petshop.cage</field>
            <field name="view_mode">list,kanban,form</field>
            <field name="context">{'search_default_available_filter': 1, 'search_default_group_by_code': 1}</field>
            <field name="search_view_id" ref="petshop_cage_search_view"/>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('petshop_cage_list_view')}),
                (0, 0, {'view_mode': 'kanban', 'view_id': ref('petshop_cage_kanban_view')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('view_petshop_cage_form')})]"/>
        </record>

        <!-- Change "parent" attribute → "menu_petshop_configuration" -->
        <menuitem id="menu_petshop_cage"
            name="Cage"
            action="action_petshop_cage"
            sequence="30"
            parent="menu_petshop_configuration"
            groups="base.group_user"/>
    </data>
</odoo>